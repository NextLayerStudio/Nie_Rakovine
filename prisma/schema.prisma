// Onko Klub - Prisma schema
// Targeting Neon (Vercel Postgres). Two URLs:
//   - DATABASE_URL: pooled connection used at runtime
//   - DIRECT_URL:   direct connection used for migrations
// Run `npx prisma migrate dev` after the database is connected.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection from Neon (used by app at runtime)
  url       = env("DATABASE_URL")
  // Direct (unpooled) connection — used by Prisma migrations
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ---------------- Users / auth ----------------

enum UserRole {
  USER
  ADMIN
}

// Curated cancer-type taxonomy used to personalise content.
enum CancerType {
  PRSNIK
  HRUBE_CREVO
  PLUCA
  PROSTATA
  KOZA
  KRCOK_MATERNICE
  TELO_MATERNICE
  VAJECNIKY
  MOCOVE_CESTY
  PODZALUDKOVA
  ZALUDOK
  PECEN
  LYMFOM
  LEUKEMIA
  MOZOG
  STITNA_ZLAZA
  HLAVA_KRK
  INE
}

enum SubscriptionPlan {
  NONE
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  CANCELLED
  PAST_DUE
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  fullName        String
  birthDate       DateTime?
  role            UserRole @default(USER)

  // Profile populated by the multi-step registration form
  profile         UserProfile?

  // Subscription
  subscriptionPlan   SubscriptionPlan   @default(NONE)
  subscriptionStatus SubscriptionStatus @default(INACTIVE)
  subscriptionStart  DateTime?
  subscriptionEnd    DateTime?

  // Relations
  eventRegistrations EventRegistration[]
  articleLikes       ArticleLike[]
  postComments       PostComment[]
  savedPosts         SavedPost[]
  forumMemberships   ForumMembership[]
  createdForums      Forum[]             @relation("ForumCreator")
  forumThreads       ForumThread[]
  forumThreadLikes   ForumThreadLike[]
  forumCommentLikes  ForumCommentLike[]
  forumComments      ForumComment[]
  profileFollows     ProfileFollow[]
  notifications      Notification[]
  savedDiscountOffers SavedDiscountOffer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Location (from "Zvoľte si miesto v ktorom sa nachádzate")
  city           String?
  region         String?
  latitude       Float?
  longitude      Float?

  // Diagnosis info
  diagnosis      String?
  diagnosisPhase String?
  diagnosisYear  Int?
  // Cancer type(s) chosen at registration — drives personalised content.
  cancerTypes    CancerType[] @default([])

  // Multi-select fields stored as string arrays
  interests      String[] @default([])
  expectations   String[] @default([])
  hearAboutUs    String[] @default([])

  // Registration consents (step 4)
  consentMembership Boolean @default(false)
  consentNewsletter Boolean @default(false)

  // Radius (km) used for "activities near me" + nearby-event notifications
  notifyRadiusKm Int      @default(50)

  // In-app notification preferences (all enabled by default at registration)
  notifyNewPosts       Boolean @default(true)
  notifyForumApproved  Boolean @default(true)
  notifyForumReactions Boolean @default(true)
  notifyEventsNearby   Boolean @default(true)

  // User's own profile photo (membership card, menu, etc.)
  avatarUrl      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------- Club profiles (Instagram-style, admin-managed) ----------------

enum ProfileCategory {
  ZDRAVA_VYZIVA
  SPONZORI
  DIAGNOZY
  NOVINKY
  AKCIE
}

model ClubProfile {
  id          String           @id @default(cuid())
  handle      String           @unique // URL slug, e.g. "onko-yoga"
  displayName String
  bio         String?
  avatarUrl   String?
  coverUrl    String?
  published   Boolean          @default(true)
  sortOrder   Int              @default(0)
  category    ProfileCategory?
  // Empty = general (everyone); otherwise targeted to these cancer types.
  cancerTypes CancerType[] @default([])

  posts    Post[]
  events   Event[]
  followers ProfileFollow[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, sortOrder])
  @@index([category, published])
}

// ---------------- Discount partners (Zľavy) ----------------

enum DiscountCategory {
  MODA
  KOZMETIKA
  JEDLO
  ZAZITKY
}

model DiscountPartner {
  id          String           @id @default(cuid())
  handle      String           @unique
  displayName String
  bio         String?
  avatarUrl   String?
  coverUrl    String?
  category    DiscountCategory
  featured    Boolean          @default(false)
  published   Boolean          @default(true)
  sortOrder   Int              @default(0)
  offers      DiscountOffer[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([published, featured, sortOrder])
  @@index([category, published, sortOrder])
}

model DiscountOffer {
  id           String   @id @default(cuid())
  partnerId    String
  partner      DiscountPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  discountText String?
  promoCode    String?
  accentColor  String?  @default("#F5D5E0")
  imageUrl     String?
  validUntil   DateTime?
  published    Boolean  @default(true)
  sortOrder    Int      @default(0)
  savedBy      SavedDiscountOffer[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([partnerId, published, sortOrder])
}

model SavedDiscountOffer {
  id        String   @id @default(cuid())
  userId    String
  offerId   String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  offer     DiscountOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, offerId])
  @@index([userId, createdAt(sort: Desc)])
}

model ProfileFollow {
  id        String   @id @default(cuid())
  userId    String
  profileId String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile   ClubProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, profileId])
  @@index([profileId])
}

// ---------------- Notifications ----------------

enum NotificationType {
  NEW_POST
  FORUM_THREAD_APPROVED
  FORUM_COMMENT_APPROVED
  FORUM_REACTION
  NEW_EVENT_NEARBY
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  href      String?
  read      Boolean          @default(false)
  postId    String?
  threadId  String?
  commentId String?
  profileId String?
  eventId   String?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, read, createdAt])
}

// ---------------- Content ----------------

enum PostType {
  VIDEO
  ARTICLE
  RECIPE
  PHOTO
  AUDIO
  NEWS
}

enum EventCategory {
  EDUKACNE
  RELAXACNE
  FYZICKE
  MENTALNE
  EXTERNE
  INTERNE
}

model Post {
  id          String   @id @default(cuid())
  profileId   String?
  profile     ClubProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  type        PostType
  title       String
  excerpt     String?
  body        String?   // markdown / html
  coverUrl    String?
  videoUrl    String?
  audioUrl    String?
  durationSec Int?
  isNovinka   Boolean  @default(false)
  published   Boolean  @default(false)
  publishedAt DateTime?
  cancerTypes CancerType[] @default([])
  likes       ArticleLike[]
  comments    PostComment[]
  images      PostImage[]
  savedBy     SavedPost[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, publishedAt(sort: Desc)])
  @@index([type, published, publishedAt(sort: Desc)])
  @@index([isNovinka, published, publishedAt(sort: Desc)])
  @@index([profileId, published, publishedAt(sort: Desc)])
}

model PostImage {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([postId])
}

model MediaAsset {
  id        String   @id @default(cuid())
  mimeType  String
  filename  String?
  category  String?
  size      Int
  data      Bytes
  createdAt DateTime @default(now())
}

model ArticleLike {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
}

model SavedPost {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([userId, createdAt(sort: Desc)])
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  body      String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
}

// ---------------- Events ----------------

model Event {
  id          String   @id @default(cuid())
  profileId   String?
  profile     ClubProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  title       String           // e.g. "ONKO YOGA"
  description String?
  category    EventCategory?
  coverUrl    String?
  location    String?
  latitude    Float?
  longitude   Float?
  startsAt    DateTime
  endsAt      DateTime?
  capacity    Int?
  published   Boolean  @default(true)
  cancerTypes CancerType[] @default([])

  registrations EventRegistration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, startsAt])
}

model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  name      String?
  surname   String?
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
}

// ---------------- Forums (Fóra) ----------------

enum ForumModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

model Forum {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String?  // profile picture (admin)
  accentColor String?  @default("#6F2380") // fallback when no imageUrl
  published   Boolean  @default(true)
  cancerTypes CancerType[] @default([])
  // Set when a regular user proposes a forum — stays unpublished until admin approves.
  createdById String?
  createdBy   User?    @relation("ForumCreator", fields: [createdById], references: [id], onDelete: SetNull)

  members ForumMembership[]
  threads ForumThread[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ForumMembership {
  id        String   @id @default(cuid())
  forumId   String
  userId    String
  forum     Forum    @relation(fields: [forumId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([forumId, userId])
}

model ForumThread {
  id        String   @id @default(cuid())
  forumId   String
  authorId  String
  title     String?
  body      String
  coverUrl  String?
  likeCount Int      @default(0)
  status    ForumModerationStatus @default(PENDING)

  forum    Forum           @relation(fields: [forumId], references: [id], onDelete: Cascade)
  author   User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes    ForumThreadLike[]
  comments ForumComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([forumId, status, createdAt(sort: Desc)])
}

model ForumThreadLike {
  id        String   @id @default(cuid())
  userId    String
  threadId  String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, threadId])
}

model ForumComment {
  id               String   @id @default(cuid())
  threadId         String
  authorId         String
  body             String
  likeCount        Int      @default(0)
  replyToCommentId String?
  status           ForumModerationStatus @default(PENDING)

  thread  ForumThread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author  User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replyTo ForumComment? @relation("CommentReplies", fields: [replyToCommentId], references: [id], onDelete: SetNull)
  replies ForumComment[] @relation("CommentReplies")
  likes   ForumCommentLike[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([threadId, status, createdAt])
}

model ForumCommentLike {
  id        String   @id @default(cuid())
  userId    String
  commentId String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   ForumComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, commentId])
}
