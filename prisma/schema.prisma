// Onko Klub - Prisma schema
// Targeting Neon (Vercel Postgres). Two URLs:
//   - DATABASE_URL: pooled connection used at runtime
//   - DIRECT_URL:   direct connection used for migrations
// Run `npx prisma migrate dev` after the database is connected.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection from Neon (used by app at runtime)
  url       = env("DATABASE_URL")
  // Direct (unpooled) connection — used by Prisma migrations
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ---------------- Users / auth ----------------

enum UserRole {
  USER
  ADMIN
}

// Curated cancer-type taxonomy used to personalise content.
enum CancerType {
  PRSNIK
  HRUBE_CREVO
  PLUCA
  PROSTATA
  KOZA
  KRCOK_MATERNICE
  TELO_MATERNICE
  VAJECNIKY
  MOCOVE_CESTY
  PODZALUDKOVA
  ZALUDOK
  PECEN
  LYMFOM
  LEUKEMIA
  MOZOG
  STITNA_ZLAZA
  HLAVA_KRK
  INE
}

enum SubscriptionPlan {
  NONE
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  CANCELLED
  PAST_DUE
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  fullName        String
  birthDate       DateTime?
  role            UserRole @default(USER)

  // Profile populated by the multi-step registration form
  profile         UserProfile?

  // Subscription
  subscriptionPlan   SubscriptionPlan   @default(NONE)
  subscriptionStatus SubscriptionStatus @default(INACTIVE)
  subscriptionStart  DateTime?
  subscriptionEnd    DateTime?

  // Relations
  eventRegistrations EventRegistration[]
  articleLikes       ArticleLike[]
  forumMemberships   ForumMembership[]
  createdForums      Forum[]             @relation("ForumCreator")
  forumThreads       ForumThread[]
  forumThreadLikes   ForumThreadLike[]
  forumComments      ForumComment[]
  profileFollows     ProfileFollow[]
  notifications      Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Location (from "Zvoľte si miesto v ktorom sa nachádzate")
  city           String?
  region         String?
  latitude       Float?
  longitude      Float?

  // Diagnosis info
  diagnosis      String?
  diagnosisPhase String?
  diagnosisYear  Int?
  // Cancer type(s) chosen at registration — drives personalised content.
  cancerTypes    CancerType[] @default([])

  // Multi-select fields stored as string arrays
  interests      String[] @default([])
  expectations   String[] @default([])
  hearAboutUs    String[] @default([])

  // Registration consents (step 4)
  consentMembership Boolean @default(false)
  consentNewsletter Boolean @default(false)

  // Radius (km) used for "activities near me" + nearby-event notifications
  notifyRadiusKm Int      @default(50)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------- Club profiles (Instagram-style, admin-managed) ----------------

model ClubProfile {
  id          String   @id @default(cuid())
  handle      String   @unique // URL slug, e.g. "onko-yoga"
  displayName String
  bio         String?
  avatarUrl   String?
  coverUrl    String?
  published   Boolean  @default(true)
  sortOrder   Int      @default(0)
  // Empty = general (everyone); otherwise targeted to these cancer types.
  cancerTypes CancerType[] @default([])

  posts    Post[]
  events   Event[]
  followers ProfileFollow[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProfileFollow {
  id        String   @id @default(cuid())
  userId    String
  profileId String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile   ClubProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, profileId])
}

// ---------------- Notifications ----------------

enum NotificationType {
  NEW_POST
  FORUM_THREAD_APPROVED
  FORUM_COMMENT_APPROVED
  NEW_EVENT_NEARBY
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  href      String?
  read      Boolean          @default(false)
  postId    String?
  threadId  String?
  commentId String?
  profileId String?
  eventId   String?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, read, createdAt])
}

// ---------------- Content ----------------

enum PostType {
  VIDEO
  ARTICLE
  RECIPE
}

enum EventCategory {
  EDUKACNE
  RELAXACNE
  FYZICKE
  MENTALNE
  EXTERNE
  INTERNE
}

model Post {
  id          String   @id @default(cuid())
  profileId   String?
  profile     ClubProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  type        PostType
  title       String
  excerpt     String?
  body        String?   // markdown / html
  coverUrl    String?
  videoUrl    String?
  published   Boolean  @default(false)
  publishedAt DateTime?
  cancerTypes CancerType[] @default([])
  likes       ArticleLike[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ArticleLike {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
}

// ---------------- Events ----------------

model Event {
  id          String   @id @default(cuid())
  profileId   String?
  profile     ClubProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  title       String           // e.g. "ONKO YOGA"
  description String?
  category    EventCategory?
  coverUrl    String?
  location    String?
  latitude    Float?
  longitude   Float?
  startsAt    DateTime
  endsAt      DateTime?
  capacity    Int?
  published   Boolean  @default(true)
  cancerTypes CancerType[] @default([])

  registrations EventRegistration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  name      String?
  surname   String?
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
}

// ---------------- Forums (Fóra) ----------------

enum ForumModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

model Forum {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String?  // profile picture (admin)
  accentColor String?  @default("#6F2380") // fallback when no imageUrl
  published   Boolean  @default(true)
  cancerTypes CancerType[] @default([])
  // Set when a regular user proposes a forum — stays unpublished until admin approves.
  createdById String?
  createdBy   User?    @relation("ForumCreator", fields: [createdById], references: [id], onDelete: SetNull)

  members ForumMembership[]
  threads ForumThread[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ForumMembership {
  id        String   @id @default(cuid())
  forumId   String
  userId    String
  forum     Forum    @relation(fields: [forumId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([forumId, userId])
}

model ForumThread {
  id        String   @id @default(cuid())
  forumId   String
  authorId  String
  title     String?
  body      String
  coverUrl  String?
  likeCount Int      @default(0)
  status    ForumModerationStatus @default(PENDING)

  forum    Forum           @relation(fields: [forumId], references: [id], onDelete: Cascade)
  author   User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes    ForumThreadLike[]
  comments ForumComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ForumThreadLike {
  id        String   @id @default(cuid())
  userId    String
  threadId  String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, threadId])
}

model ForumComment {
  id        String   @id @default(cuid())
  threadId  String
  authorId  String
  body      String
  status    ForumModerationStatus @default(PENDING)

  thread ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User        @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
