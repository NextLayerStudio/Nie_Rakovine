# Neon (Vercel Postgres) connection string for Prisma
# Pooled connection used by app (Prisma serverless friendly)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true&connection_limit=1"
# Direct connection used by Prisma migrations
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth — session signing (>= 16 chars)
AUTH_SECRET="change-me-long-random-string"

# Public app URL (used in email links)
APP_URL="http://localhost:3000"

# Legacy / optional
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="http://localhost:3000"

# Admin bootstrap (used by seed script)
ADMIN_EMAIL="admin@onkoklub.sk"
ADMIN_PASSWORD="change-me-strong-password"

# Resend — transactional email
# Get API key: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
# Must use a domain verified in Resend (or onboarding@resend.dev for testing to your own inbox)
EMAIL_FROM="Onko Klub <noreply@yourdomain.sk>"
